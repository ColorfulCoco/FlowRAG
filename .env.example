# FlowRAG Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================================
# LLM / Embedding API (OpenAI-compatible)
# ============================================================
API_KEY=""
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-plus
EMBEDDING_MODEL=text-embedding-v4

# Override per stage (optional, defaults to the values above)
# BUILD_LLM_API_KEY=
# BUILD_LLM_BASE_URL=
# BUILD_LLM_MODEL=
# BUILD_EMB_API_KEY=
# BUILD_EMB_BASE_URL=
# BUILD_EMB_MODEL=

# RETRIEVE_LLM_API_KEY=
# RETRIEVE_LLM_BASE_URL=
# RETRIEVE_LLM_MODEL=
# RETRIEVE_EMB_API_KEY=
# RETRIEVE_EMB_BASE_URL=
# RETRIEVE_EMB_MODEL=

# EVALUATE_LLM_API_KEY=
# EVALUATE_LLM_BASE_URL=
# EVALUATE_LLM_MODEL=qwen-max
# EVALUATE_EMB_API_KEY=
# EVALUATE_EMB_BASE_URL=
# EVALUATE_EMB_MODEL=text-embedding-v4

# ============================================================
# API 重试（LLM/Embedding 失败时：429限流、网络抖动等）
# ============================================================
# API_RETRY_INTERVAL_SECONDS=10   # 每次重试前等待秒数
# API_RETRY_MAX_ATTEMPTS=10      # 最大重试次数

# ============================================================
# 日志级别（0=精简日志+进度条，1=详细日志）
# ============================================================
# LOG_VERBOSE=0
